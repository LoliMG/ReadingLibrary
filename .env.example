# Copy to ".env" and fill in real values (never commit .env).

# MySQL (used by Express / api on Vercel too — add the same keys in Vercel → Settings → Environment Variables)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Optional: true | false — on Vercel, TLS is on by default unless you set DB_SSL=false
DB_SSL=

# Optional: local Express port (default 4000)
PORT=4000

# Optional: only if the API is on another origin (no trailing slash). Same host as the site → leave empty.
# VITE_API_URL=
